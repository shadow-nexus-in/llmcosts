# Cloudflare Pages — URL Routing Rules
# Serves dist/ as root. These rules enable clean URLs without .html extensions.

# ── Clean URL rewrites ──
/models/*      /models/:splat.html       200
/compare/*     /compare/:splat.html      200
/compare       /compare/index.html       200
/configs       /configs/index.html       200
/daily-report  /daily-report/index.html  200

# ── LLMs.txt shards ──
/llms.txt      /llms.txt      200
/llms-full.txt /llms-full.txt 200
/llms-*.txt    /:splat        200

# ── Sitemap & Robots ──
/sitemap.xml  /sitemap.xml  200
/robots.txt   /robots.txt   200

# ── Affiliate Dynamic Proxy Routes ──
/out/cloud  https://m.do.co/c/your_your_digitalocean_affiliate_id_here  301
/out/api    https://openrouter.ai/api/v1?ref=llmcosts                   301

